# =============================================================================
# Variables d'environnement — PRODUCTION (frontend Nuxt)
#
# Copier ce fichier en `.env.prod` (ignoré par git) et adapter les valeurs.
# Démarrage :
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# Note : aucun secret ne doit être placé dans une variable préfixée par
# NUXT_PUBLIC_ — celles-ci sont exposées au navigateur dans le bundle JS.
# =============================================================================

# --- Application ---------------------------------------------------------------

NODE_ENV=production

# --- Connexion à l'API backend -------------------------------------------------
#
# URL publique de l'API en production. TLS obligatoire.

NUXT_PUBLIC_API_BASE=https://api.ressources-relationnelles.example

# URL publique du frontend (redirections internes et liens absolus)
NUXT_PUBLIC_APP_BASE_URL=https://ressources-relationnelles.example
