# =============================================================================
# Variables d'environnement — PRÉ-PRODUCTION (frontend Nuxt)
#
# Copier ce fichier en `.env.preprod` (ignoré par git) et adapter les valeurs.
# Démarrage :
#   docker compose -f docker-compose.preprod.yml --env-file .env.preprod up -d
# =============================================================================

# --- Application ---------------------------------------------------------------

NODE_ENV=preproduction

# --- Connexion à l'API backend -------------------------------------------------
#
# URL publique de l'API en pré-production. Le client Nuxt l'utilise depuis le
# navigateur — elle doit donc être accessible publiquement (TLS recommandé).
# Si frontend et backend sont sur le même hôte Docker, l'alias réseau interne
# `http://api:3001` peut être utilisé pour les appels server-side uniquement,
# mais NUXT_PUBLIC_API_BASE est exposée au navigateur.

NUXT_PUBLIC_API_BASE=https://api.preprod.ressources-relationnelles.example

# URL publique du frontend (pour les redirections internes et les liens absolus)
NUXT_PUBLIC_APP_BASE_URL=https://preprod.ressources-relationnelles.example
